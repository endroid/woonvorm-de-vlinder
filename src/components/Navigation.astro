---
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

const navItems = [
  { path: '/', title: 'Startpagina' },
  { path: '/de-stichting', title: 'De Stichting' },
  { path: '/algemene-gegevens', title: 'Algemene gegevens' },
  { path: '/15-jaar-de-vlinder', title: '15 jaar De Vlinder' },
  { path: '/financieel-verslag', title: 'Financieel verslag' },
  { path: '/nieuwe-onderwerpen', title: 'Nieuwe onderwerpen' },
  { path: '/fondsen', title: 'Fondsen' },
  { path: '/vrienden-van-de-vlinder', title: 'Vrienden van De Vlinder' },
];

const currentDate = new Date().toLocaleDateString('nl-NL', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<header class="site-header" transition:name="site-header" transition:animate="initial">
  <div class="container top-bar">
    <a href="/" class="brand" aria-label="Woonvorm De Vlinder - startpagina">
      <img class="brand-mark" src="/images/vlinder-logo.webp" width="44" height="44" alt="" />
      <span class="brand-text">
        <span class="brand-name">Woonvorm De Vlinder</span>
        <span class="brand-sub">Prinsenbeek</span>
      </span>
    </a>
    <p class="date" aria-hidden="true">{currentDate}</p>
    <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="site-nav">
      <svg class="icon-open" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" /></svg>
      <svg class="icon-close" viewBox="0 0 24 24" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" /></svg>
      <span class="sr-only">Menu</span>
    </button>
  </div>
  <nav id="site-nav" class="site-nav" aria-label="Hoofdnavigatie">
    <ul class="container">
      {navItems.map((item) => (
        <li>
          <a href={item.path} aria-current={currentPath === item.path ? 'page' : undefined}>
            {item.title}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<script>
  function bindMenu() {
    const toggle = document.querySelector('.menu-toggle');
    const header = document.querySelector('.site-header');
    if (!(toggle instanceof HTMLElement) || !header) return;
    toggle.addEventListener('click', () => {
      const open = header.classList.toggle('nav-open');
      toggle.setAttribute('aria-expanded', String(open));
    });
  }
  document.addEventListener('astro:page-load', bindMenu);
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgb(255 255 255 / 0.92);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--line);
  }

  .site-header .container {
    max-width: 1220px;
  }

  .top-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 0.8rem;
    padding-bottom: 0.6rem;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
  }

  .brand-mark {
    width: 44px;
    height: 44px;
    flex-shrink: 0;
    object-fit: contain;
  }

  .brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  .brand-name {
    font-size: 1.2rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    color: var(--brand-800);
  }

  .brand-sub {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--green-700);
  }

  .date {
    margin: 0;
    font-size: 0.88rem;
    color: var(--ink-600);
  }

  .date::first-letter {
    text-transform: uppercase;
  }

  .menu-toggle {
    display: none;
    background: none;
    border: none;
    padding: 0.4rem;
    color: var(--brand-800);
    cursor: pointer;
  }

  .menu-toggle svg {
    width: 26px;
    height: 26px;
    display: block;
  }

  .menu-toggle .icon-close {
    display: none;
  }

  .nav-open .menu-toggle .icon-open {
    display: none;
  }

  .nav-open .menu-toggle .icon-close {
    display: block;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }

  .site-nav ul {
    list-style: none;
    margin-block: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.15rem;
    padding-top: 0.15rem;
    padding-bottom: 0.65rem;
  }

  .site-nav a {
    display: block;
    padding: 0.42rem 0.65rem;
    border-radius: 999px;
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--ink-600);
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .site-nav a:hover {
    background: var(--brand-50);
    color: var(--brand-700);
  }

  .site-nav a[aria-current='page'] {
    background: var(--brand-700);
    color: #fff;
  }

  @media (max-width: 920px) {
    .date {
      display: none;
    }

    .menu-toggle {
      display: block;
    }

    .site-nav {
      display: none;
      border-top: 1px solid var(--line);
    }

    .nav-open .site-nav {
      display: block;
    }

    .site-nav ul {
      flex-direction: column;
      gap: 0.15rem;
      padding-top: 0.6rem;
      padding-bottom: 0.8rem;
    }

    .site-nav a {
      padding: 0.6rem 0.85rem;
      border-radius: var(--radius-sm);
      white-space: normal;
    }
  }
</style>
