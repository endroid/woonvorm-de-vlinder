---
import Layout from '../layouts/Layout.astro';
---

<Layout title="De Stichting">
  <div class="container container-narrow">
    <header class="page-header">
      <span class="eyebrow">Sinds juni 2005</span>
      <h1>De Stichting</h1>
      <p class="lead">
        Opgericht door vijf ouderparen uit Prinsenbeek, met één doel: een
        veilige en zelfstandige woonplek voor hun kinderen.
      </p>
    </header>

    <div class="page-body">
      <div class="card">
        <p>
          De stichting is in juni 2005 opgericht door vijf ouderparen uit Prinsenbeek en draagt de naam
          <strong>"STICHTING WOONVORM DE VLINDER"</strong>.
        </p>
        <p>
          De stichting beheert "De Vlinder", een kleinschalig wooncomplex met vijf appartementen aan de
          Kapelstraat in <strong>Prinsenbeek</strong>, gemeente Breda.
        </p>
        <p>
          Deze appartementen worden momenteel &mdash; onder begeleiding &mdash; zelfstandig bewoond door
          vijf mensen met een verstandelijke beperking.
        </p>
        <h2>De huidige bewoners zijn:</h2>
        <figure>
          <img src="/images/bewoners.jpg" alt="De bewoners van De Vlinder" width="700" />
        </figure>
      </div>
    </div>
  </div>
</Layout>

<style>
  figure {
    margin-top: 1.2rem;
  }

  figure img {
    width: 100%;
    max-width: 700px;
  }
</style>
