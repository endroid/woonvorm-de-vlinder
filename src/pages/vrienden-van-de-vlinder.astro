const half = Math.ceil(friends.length / 2);
const columns = [friends.slice(0, half), friends.slice(half)];
---

<Layout title="Vrienden van de Vlinder">
  <div class="container container-narrow">
    <header class="page-header">
      <span class="eyebrow">Onze donateurs</span>
      <h1>Vrienden van De Vlinder {currentYear}</h1>
      <p class="lead">
        De vrienden van De Vlinder doneren elk jaar tenminste &euro;&nbsp;100,&mdash;.
        Met deze donaties kan het bestuur het jaarlijkse structurele tekort van ruim
        &euro;&nbsp;10.000,&mdash; verminderen. Het betreft de kosten voor onderhoud en
        vervanging van de algemene middelen in de gemeenschappelijke ruimtes.
      </p>
    </header>

    <div class="page-body">
      <section class="card">
        <h2>Hartelijk dank aan al onze vrienden</h2>
        <div class="friends">
          {columns.map((column) => (
            <ul>
              {column.map((name) => <li>{name}</li>)}
            </ul>
          ))}
        </div>
      </section>
    </div>
  </div>
</Layout>

<style>
  .friends {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 3rem;
    margin-top: 1.2rem;
  }

  .friends ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .friends li {
    font-weight: 600;
    padding: 0.45rem 0;
    border-bottom: 1px solid var(--line);
  }

  .friends li:last-child {
    border-bottom: none;
  }

  @media (max-width: 680px) {
    .friends {
      grid-template-columns: 1fr;
    }

    .friends ul:first-child li:last-child {
      border-bottom: 1px solid var(--line);
    }
  }
</style>
